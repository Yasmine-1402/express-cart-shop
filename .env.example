## Example environment variables for ExpressCart (Heba Planet)
# Copy to .env and fill in real values. Do NOT check .env into source control.

# MongoDB Atlas connection string

# Recommended: either set MONGO_URI or DATABASE_URL
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/heba-planet
DATABASE_URL=mongodb+srv://<user>:<password>@cluster0.mongodb.net/heba-planet

# Local Compass URL (if used)
COMPASS_URL=mongodb://localhost:27017/heba-planet

# Email (SMTP) settings
EMAIL_USER=you@example.com
EMAIL_PASSWORD=your-email-password-or-app-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Admin credentials used by create-admin.js (optional)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# App secrets
SECRET_COOKIE=
SECRET_SESSION=

# Node environment
NODE_ENV=production

# Session / security settings
# Set ENABLE_CSRF=true to enable server-side CSRF protection (may require template changes)
ENABLE_CSRF=false
# Session cookie max age in ms (default 900000 = 15 minutes)
SESSION_MAX_AGE=900000
# Session SameSite setting (lax/strict/none)
SESSION_SAME_SITE=lax

# Rate limiting (window in ms and max requests per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Auth endpoint rate limit (lower value to protect login endpoints)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
