<div class="col-md-12">
    <div class="hp-login-card" style="max-width:480px;">
        <div class="login-icon">✨</div>
        <h2>Create Your Account</h2>
        <p style="text-align:center;color:var(--hp-text-light);font-size:14px;margin-bottom:24px;">Join Heba Planet and start your child's learning journey</p>
        <form id="customer-signup-form" role="form" novalidate="false">
            <div class="row">
                <div class="col-sm-6">
                    <div class="form-group">
                        <label for="signup-firstName">First Name <span style="color:var(--hp-danger);">*</span></label>
                        <input type="text" class="form-control" id="signup-firstName" name="firstName" placeholder="First name" required>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="form-group">
                        <label for="signup-lastName">Last Name <span style="color:var(--hp-danger);">*</span></label>
                        <input type="text" class="form-control" id="signup-lastName" name="lastName" placeholder="Last name" required>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label for="signup-email">Email Address <span style="color:var(--hp-danger);">*</span></label>
                <input type="email" class="form-control" id="signup-email" name="email" placeholder="your@email.com" required>
            </div>
            <div class="form-group">
                <label for="signup-phone">Phone Number</label>
                <input type="tel" class="form-control" id="signup-phone" name="phone" placeholder="e.g. 01xxxxxxxxx">
            </div>

            <hr style="border-color:var(--hp-border);margin:16px 0 12px;">
            <p style="font-weight:800;font-size:13px;color:var(--hp-primary-dark);margin-bottom:12px;text-transform:uppercase;letter-spacing:1px;">📍 Address <span style="font-weight:400;color:var(--hp-text-muted);text-transform:none;letter-spacing:0;">(optional)</span></p>

            <div class="row">
                <div class="col-sm-6">
                    <div class="form-group">
                        <label for="signup-country">Country</label>
                        <select class="form-control country-selector" id="signup-country" name="country" data-city-select="signup-city" data-city-input="signup-cityText">
                            {{#each countryList}}
                            <option {{selectState this "Egypt"}} value="{{this}}">{{this}}</option>
                            {{/each}}
                        </select>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="form-group">
                        <label for="signup-city">City</label>
                        <!-- Egypt cities dropdown -->
                        <select class="form-control city-dropdown" id="signup-city" name="state">
                            <option value="" disabled selected>Select City</option>
                            <option value="Cairo">Cairo</option>
                            <option value="Alexandria">Alexandria</option>
                            <option value="Giza">Giza</option>
                            <option value="Port Said">Port Said</option>
                            <option value="Suez">Suez</option>
                            <option value="Luxor">Luxor</option>
                            <option value="Aswan">Aswan</option>
                            <option value="Asyut">Asyut</option>
                            <option value="Beheira">Beheira</option>
                            <option value="Beni Suef">Beni Suef</option>
                            <option value="Dakahlia">Dakahlia</option>
                            <option value="Damietta">Damietta</option>
                            <option value="Fayoum">Fayoum</option>
                            <option value="Gharbia">Gharbia</option>
                            <option value="Hurghada">Hurghada</option>
                            <option value="Ismailia">Ismailia</option>
                            <option value="Kafr El Sheikh">Kafr El Sheikh</option>
                            <option value="Matruh">Matruh</option>
                            <option value="Minya">Minya</option>
                            <option value="Monufia">Monufia</option>
                            <option value="New Valley">New Valley</option>
                            <option value="North Sinai">North Sinai</option>
                            <option value="Qalyubia">Qalyubia</option>
                            <option value="Qena">Qena</option>
                            <option value="Red Sea">Red Sea</option>
                            <option value="Sharqia">Sharqia</option>
                            <option value="Sohag">Sohag</option>
                            <option value="South Sinai">South Sinai</option>
                        </select>
                        <!-- Free text for international -->
                        <input type="text" class="form-control city-text" id="signup-cityText" name="state" placeholder="Enter your city" style="display:none;">
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label for="signup-address1">Street Address</label>
                <input type="text" class="form-control" id="signup-address1" name="address1" placeholder="Street name, building, floor">
            </div>

            <hr style="border-color:var(--hp-border);margin:16px 0 12px;">

            <div class="form-group">
                <label for="signup-password">Password <span style="color:var(--hp-danger);">*</span></label>
                <input type="password" class="form-control" id="signup-password" name="password" placeholder="Min 5 characters" minlength="5" required>
            </div>
            <button class="btn btn-primary btn-block" id="customerSignupBtn" type="submit" style="padding:14px;font-size:16px;">✨ Create Account</button>
        </form>
        <div style="text-align:center;margin-top:20px;padding-top:20px;border-top:1px solid var(--hp-border);">
            <p style="color:var(--hp-text-light);font-size:14px;margin-bottom:0;">Already have an account? <a href="/customer/login" style="font-weight:700;">Sign in</a></p>
        </div>
    </div>
</div>
