<div class="col-md-12">
    <div class="hp-login-card">
        <div class="login-icon">🪐</div>
        <h2>{{ @root.__ "Please sign in" }}</h2>
        <form class="form-signin" method="post" role="form" data-toggle="validator" action="/customer/login_action">
            <div class="form-group">
                <input type="email" id="email" name="email" class="form-control" placeholder="Email address" required autofocus>
            </div>
            <div class="form-group">
                <input type="password" id="password" name="password" class="form-control" placeholder="Password" required>
            </div>
            <button class="btn btn-primary btn-block" id="customerloginForm" type="submit">{{ @root.__ "Sign in" }} →</button>
        </form>
        <div style="text-align:center;margin-top:20px;padding-top:20px;border-top:1px solid var(--hp-border);">
            <p style="color:var(--hp-text-light);font-size:14px;margin-bottom:8px;">Don't have an account yet?</p>
            <a href="/customer/signup" class="btn btn-outline-primary btn-block" style="font-weight:700;">✨ Create Account</a>
        </div>
        <div style="text-align:center;margin-top:12px;">
            <a href="/customer/forgotten" style="font-size:13px;color:var(--hp-text-muted);font-weight:600;">Forgot your password?</a>
        </div>
    </div>
</div>
